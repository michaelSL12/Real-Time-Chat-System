# ---------------------------------------------------------------------
# Rate limit
# ---------------------------------------------------------------------
MESSAGE_RATE_LIMIT=5
MESSAGE_RATE_WINDOW_SECONDS=10

# ---------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------
SECRET_KEY=my_dummy_secret_key_for_git
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7


# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chat
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/chat_test